---
import BaseLayout from "../components/BaseLayout.astro";

const illustrationModules = import.meta.glob("../content/illustrations/*.md", { eager: true });
const illustrations = Object.values(illustrationModules).map((module) => {
  const data = module.frontmatter;
  return {
    ...data,
    coverImage: data.image,
    Content: module.default,
  };
}).filter((illustration) => illustration.id);
---

<BaseLayout title="イラスト一覧">
  <main class="page-shell">
    <h1 class="gallery-title">GALLERY</h1>

    <div class="illustration-grid" aria-label="イラスト一覧">
      {illustrations.map((illustration) => (
        <a class="illustration-tile" href={`/illustrations/${illustration.id}/`} aria-label={illustration.title}>
          <img src={illustration.coverImage} alt={illustration.title} />
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .gallery-title {
    margin: 0 0 28px;
    color: var(--blue-deep);
    font-size: clamp(28px, 5vw, 52px);
    text-align: center;
    letter-spacing: 0;
  }

  .illustration-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(8px, 1.5vw, 16px);
    max-width: 920px;
    margin: 0 auto;
  }

  .illustration-tile {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--pale);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .illustration-tile:hover {
    transform: translateY(-3px);
    box-shadow: var(--soft-shadow);
  }

  .illustration-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 520px) {
    .illustration-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>