---
import BaseLayout from "../components/BaseLayout.astro";

const illustrationModules = import.meta.glob("../content/illustrations/*.md", { eager: true });
const illustrations = Object.values(illustrationModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
}));
---

<BaseLayout title="イラスト一覧">
  <main class="page-shell">
    <h1 class="page-title">イラスト</h1>
    <p class="lead">キャラクターに紐づく記録画を一覧できます。</p>

    <div class="illustration-grid">
      {illustrations.map((illustration) => (
        <article class="illustration-card panel">
          <img src={illustration.image} alt={illustration.title} />
          <div>
            <h2>{illustration.title}</h2>
            <p>{illustration.tags?.join(" / ")}</p>
          </div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .illustration-grid {
    columns: 3 240px;
    column-gap: 22px;
    margin-top: 36px;
  }

  .illustration-card {
    break-inside: avoid;
    margin-bottom: 22px;
    overflow: hidden;
  }

  .illustration-card img {
    width: 100%;
  }

  .illustration-card div {
    padding: 18px;
  }

  .illustration-card h2 {
    margin: 0 0 8px;
    font-size: 20px;
  }

  .illustration-card p {
    margin: 0;
    color: var(--muted);
  }
</style>
