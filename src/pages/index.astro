  .ad-section {
    padding: 56px 0 24px;
  }

  .ad-note {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .ad-carousel {
    position: relative;
  }

  .ad-track {
    display: grid;
    grid-auto-columns: 100%;
    grid-auto-flow: column;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    border-radius: 18px;
  }

  .ad-track::-webkit-scrollbar {
    display: none;
  }

  .ad-slide {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 4;
    min-height: 0;
    color: #fff;
    text-decoration: none;
    background: var(--pale);
    border: 1px solid var(--line);
    border-radius: 18px;
    box-shadow: var(--soft-shadow);
    scroll-snap-align: start;
  }

  .ad-slide img {
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 4;
    min-height: 0;
    object-fit: cover;
  }

  .ad-slide::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 48%;
    background: linear-gradient(180deg, rgba(40, 55, 69, 0), rgba(40, 55, 69, 0.62));
  }

  .ad-slide span {
    position: absolute;
    left: clamp(16px, 4vw, 34px);
    right: clamp(16px, 4vw, 34px);
    bottom: clamp(14px, 3vw, 28px);
    z-index: 1;
    font-size: clamp(20px, 4vw, 34px);
    font-weight: 700;
    line-height: 1.4;
    text-shadow: 0 2px 12px rgba(40, 55, 69, 0.36);
  }

  .ad-arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    padding: 0;
    color: var(--blue-deep);
    font-size: 34px;
    line-height: 1;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--line);
    border-radius: 999px;
    box-shadow: 0 12px 26px rgba(93, 125, 148, 0.18);
    cursor: pointer;
    opacity: 0;
    transform: translateY(-50%);
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .ad-carousel:hover .ad-arrow,
  .ad-carousel:focus-within .ad-arrow {
    opacity: 1;
  }

  .ad-arrow:hover {
    transform: translateY(-50%) scale(1.05);
  }

  .ad-arrow-prev {
    left: 12px;
  }

  .ad-arrow-next {
    right: 12px;
  }

  .news-section {
    padding: 56px 0 24px;
  }

  .section-heading-row {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .section-heading-row .section-title {
    margin-bottom: 0;
  }

  .section-link {
