    padding: 8px clamp(14px, 3vw, 22px);
  }

  .top-news-item {
    display: grid;
    grid-template-columns: 128px minmax(0, 1fr);
    gap: 18px;
    align-items: center;
    padding: 14px 0;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }

  .top-news-item:last-child {
    border-bottom: 0;
  }

  .top-news-item time {
