---
import BaseLayout from "../components/BaseLayout.astro";
import FlowGallery from "../components/FlowGallery.astro";
import WorldContent from "../content/pages/world.md";

const characterModules = import.meta.glob("../content/characters/*.md", { eager: true });
const illustrationModules = import.meta.glob("../content/illustrations/*.md", { eager: true });
const museumModules = import.meta.glob("../content/museums/*.md", { eager: true });
const newsModules = import.meta.glob("../content/news/*.md", { eager: true });
const adModules = import.meta.glob("../content/ads/*.md", { eager: true });

const getIdFromPath = (path) => path.split("/").pop().replace(".md", "");
const getSortTime = (value) => {
  const time = new Date(value || 0).getTime();
  return Number.isNaN(time) ? 0 : time;
};
const getDateKey = (value) => {
  if (!value) return "";
  const text = String(value);
  const match = text.match(/^\d{4}-\d{2}-\d{2}/);
  if (match) return match[0];
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return text;
  return date.toLocaleDateString("sv-SE", { timeZone: "Asia/Tokyo" });
};
const getDisplayOrder = (value) => {
  const order = Number(value);
  return Number.isFinite(order) ? order : 9999;
};
const formatDate = (value) => {
  if (!value) return "未設定";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleDateString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit" });
};

const characters = Object.values(characterModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
})).filter((character) => character.id);

const illustrations = Object.values(illustrationModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
})).filter((illustration) => illustration.id);

const characterItems = [...characters]
  .sort(() => Math.random() - 0.5)
  .map((character) => ({
    title: character.name,
    image: character.image,
    href: `/characters/${character.id}/`,
  }));
const museums = Object.values(museumModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
})).filter((museum) => museum.id);

const illustrationItems = [...illustrations]
  .sort(() => Math.random() - 0.5)
  .map((illustration) => ({
    title: illustration.title,
    image: illustration.image,
    href: `/illustrations/${illustration.id}/`,
  }));
const ticketIllustrations = illustrations
  .filter((illustration) => illustration.image)
  .map((illustration) => ({
    title: illustration.title,
    image: illustration.image,
    href: `/illustrations/${illustration.id}/`,
  }));
const latestNews = Object.entries(newsModules)
  .map(([path, module]) => ({
    id: module.frontmatter.id || getIdFromPath(path),
    title: module.frontmatter.title || "無題のお知らせ",
    publishedAt: module.frontmatter.publishedAt || "",
    order: getDisplayOrder(module.frontmatter.order),
    dateKey: getDateKey(module.frontmatter.publishedAt),
  }))
  .sort((a, b) => String(b.dateKey).localeCompare(String(a.dateKey), "ja") || b.order - a.order || getSortTime(b.publishedAt) - getSortTime(a.publishedAt) || String(b.id).localeCompare(String(a.id), "ja"))
  .slice(0, 5);
const latestAds = Object.entries(adModules)
  .map(([path, module]) => ({
    id: module.frontmatter.id || getIdFromPath(path),
    title: module.frontmatter.title || "無題の幻覚広告",
    publishedAt: module.frontmatter.publishedAt || "",
    bannerImage: module.frontmatter.bannerImage || "/images/uploads/logo.webp",
  }))
  .sort((a, b) => getSortTime(b.publishedAt) - getSortTime(a.publishedAt) || String(b.id).localeCompare(String(a.id), "ja"))
  .slice(0, 5);
const loopingAds = latestAds.length > 1 ? [...latestAds, ...latestAds] : latestAds;
const diagnosisQuestions = [
  { text: "休日はどう過ごしたい？", answers: [
    { label: "一人で何かを作っていたい", points: { tasuku: 2, sino: 1 } },
    { label: "自然や博物館をゆっくり見て回る", points: { sion: 2, nobu: 1 } },
    { label: "仲間と遊びに出掛ける", points: { haru: 2, azusa: 1 } },
    { label: "家でゆっくり身体を休める", points: { nobu: 2, gunso: 1 } },
  ] },
  { text: "誰かが困っていたら？", answers: [
    { label: "黙って手伝う", points: { sino: 2, tasuku: 1 } },
    { label: "原因を一緒に考える", points: { sion: 2, gunso: 1 } },
    { label: "「大丈夫！」と励ます", points: { azusa: 2, haru: 1 } },
    { label: "自分が代わりに引き受ける", points: { gunso: 2, sino: 1 } },
  ] },
  { text: "一番好きな言葉は？", answers: [
    { label: "継続", points: { tasuku: 2, gunso: 1 } },
