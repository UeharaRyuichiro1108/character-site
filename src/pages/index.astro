---
import BaseLayout from "../components/BaseLayout.astro";
import FlowGallery from "../components/FlowGallery.astro";
import WorldContent from "../content/pages/world.md";

const characterModules = import.meta.glob("../content/characters/*.md", { eager: true });
const illustrationModules = import.meta.glob("../content/illustrations/*.md", { eager: true });
const museumModules = import.meta.glob("../content/museums/*.md", { eager: true });

const characters = Object.values(characterModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
})).filter((character) => character.id);

const illustrations = Object.values(illustrationModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
})).filter((illustration) => illustration.id);

const characterItems = [...characters]
  .sort(() => Math.random() - 0.5)
  .map((character) => ({
    title: character.name,
    image: character.image,
    href: `/characters/${character.id}/`,
  }));
const museums = Object.values(museumModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
})).filter((museum) => museum.id);

const illustrationItems = [...illustrations]
  .sort(() => Math.random() - 0.5)
  .map((illustration) => ({
    title: illustration.title,
    image: illustration.image,
    href: `/illustrations/${illustration.id}/`,
  }));
const diagnosisQuestions = [
  { text: "休日はどう過ごしたい？", answers: [
    { label: "一人で何かを作っていたい", points: { tasuku: 2, sino: 1 } },
    { label: "自然や博物館をゆっくり見て回る", points: { sion: 2, nobu: 1 } },
    { label: "仲間と遊びに出掛ける", points: { haru: 2, azusa: 1 } },
    { label: "家でゆっくり身体を休める", points: { nobu: 2, gunso: 1 } },
  ] },
  { text: "誰かが困っていたら？", answers: [
    { label: "黙って手伝う", points: { sino: 2, tasuku: 1 } },
    { label: "原因を一緒に考える", points: { sion: 2, gunso: 1 } },
    { label: "「大丈夫！」と励ます", points: { azusa: 2, haru: 1 } },
    { label: "自分が代わりに引き受ける", points: { gunso: 2, sino: 1 } },
  ] },
  { text: "一番好きな言葉は？", answers: [
    { label: "継続", points: { tasuku: 2, gunso: 1 } },
    { label: "理解", points: { sion: 2, nobu: 1 } },
    { label: "成長", points: { azusa: 2, haru: 1 } },
    { label: "家族", points: { sino: 2, nobu: 1 } },
  ] },
  { text: "友達からよく言われるのは？", answers: [
    { label: "真面目だね", points: { tasuku: 2, gunso: 1 } },
    { label: "優しいね", points: { sion: 2, sino: 1 } },
    { label: "元気だね", points: { haru: 2, azusa: 1 } },
    { label: "落ち着くね", points: { nobu: 2, sion: 1 } },
  ] },
  { text: "一番得意なのは？", answers: [
    { label: "手先を使うこと", points: { tasuku: 2, azusa: 1 } },
    { label: "観察すること", points: { sion: 2, nobu: 1 } },
    { label: "人を笑わせること", points: { haru: 2, azusa: 1 } },
    { label: "誰かを支えること", points: { sino: 2, gunso: 1 } },
  ] },
  { text: "博物館で一番見たい展示は？", answers: [
    { label: "修復室", points: { tasuku: 2, sino: 1 } },
    { label: "標本・自然展示", points: { sion: 2, azusa: 1 } },
    { label: "昔の暮らし", points: { haru: 2, nobu: 1 } },
    { label: "軍事・歴史資料", points: { gunso: 2, tasuku: 1 } },
  ] },
  { text: "落ち込んだ時は？", answers: [
    { label: "仕事や趣味に没頭する", points: { tasuku: 2, sino: 1 } },
    { label: "一人で考える", points: { sion: 2, nobu: 1 } },
    { label: "誰かに話す", points: { haru: 2, azusa: 1 } },
    { label: "とにかく動く", points: { gunso: 2, azusa: 1 } },
  ] },
  { text: "あなたにとって一番大切なのは？", answers: [
    { label: "技術", points: { tasuku: 2, sion: 1 } },
    { label: "知識", points: { sion: 2, gunso: 1 } },
    { label: "仲間", points: { sino: 2, haru: 1 } },
    { label: "希望", points: { azusa: 2, haru: 1 } },
  ] },
  { text: "何かを教えるなら？", answers: [
    { label: "手本を見せる", points: { tasuku: 2, gunso: 1 } },
    { label: "理由から説明する", points: { sion: 2, nobu: 1 } },
    { label: "一緒にやってみる", points: { azusa: 2, haru: 1 } },
    { label: "相手のペースに合わせる", points: { sino: 2, nobu: 1 } },
  ] },
  { text: "一番好きな季節は？", answers: [
    { label: "秋", points: { tasuku: 2, sino: 1 } },
    { label: "夏", points: { sion: 2, haru: 1 } },
    { label: "春", points: { azusa: 2, nobu: 1 } },
    { label: "冬", points: { gunso: 2, sino: 1 } },
  ] },
  { text: "理想のチームは？", answers: [
    { label: "黙って信頼し合える", points: { tasuku: 2, nobu: 1 } },
    { label: "助け合える", points: { sino: 2, gunso: 1 } },
    { label: "いつも笑っている", points: { haru: 2, azusa: 1 } },
    { label: "お互い高め合える", points: { sion: 2, azusa: 1 } },
  ] },
  { text: "戦うならどんな役？", answers: [
    { label: "後方支援", points: { tasuku: 2, sino: 1 } },
    { label: "状況分析", points: { sion: 2, nobu: 1 } },
    { label: "仲間の強化", points: { azusa: 2, haru: 1 } },
    { label: "最前線", points: { gunso: 2, sino: 1 } },
  ] },
  { text: "誰かから褒められたいのは？", answers: [
    { label: "「器用だね」", points: { tasuku: 2, azusa: 1 } },
    { label: "「優しいね」", points: { sion: 2, nobu: 1 } },
    { label: "「一緒にいて楽しい」", points: { haru: 2, azusa: 1 } },
    { label: "「頼りになる」", points: { gunso: 2, sino: 1 } },
  ] },
  { text: "あなたが未来へ残したいものは？", answers: [
    { label: "思い出", points: { tasuku: 2, nobu: 1 } },
    { label: "真実", points: { sion: 2, gunso: 1 } },
    { label: "笑顔", points: { haru: 2, azusa: 1 } },
    { label: "絆", points: { sino: 2, gunso: 1 } },
  ] },
];

const diagnosisCharacters = Object.fromEntries(
  characters.map((character) => [character.id, {
    id: character.id,
    name: character.name,
    image: character.image,
    summary: character.catchcopy || character.role || character.group || "",
    href: `/characters/${character.id}/`,
  }])
);

const diagnosisConfig = {
  questions: diagnosisQuestions,
  characters: diagnosisCharacters,
};
const museumDiagnosisQuestions = [
  { text: "あなたが博物館を作るなら？", answers: [
    { label: "地域の歴史を後世へ残したい", points: { aidate: 2, hokudai: 1 } },
    { label: "地域のみんなが集まる場所にしたい", points: { yubari: 2, otaru: 1 } },
    { label: "最先端の研究成果を展示したい", points: { hokudai: 2, aidate: 1 } },
    { label: "展示そのものを楽しんでもらいたい", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "一番好きな言葉は？", answers: [
    { label: "伝統", points: { aidate: 2, otaru: 1 } },
    { label: "一山一家", points: { yubari: 2, otaru: 1 } },
    { label: "真理", points: { hokudai: 2, aidate: 1 } },
    { label: "思い出", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "仲間と仕事をするときは？", answers: [
    { label: "自分の担当を最後までやる", points: { aidate: 2, hokudai: 1 } },
    { label: "助け合うことを優先", points: { yubari: 2, otaru: 1 } },
    { label: "新しい方法を考える", points: { hokudai: 2, aidate: 1 } },
    { label: "みんなが楽しめる工夫をする", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "あなたが一番わくわくする展示は？", answers: [
    { label: "修復された展示物", points: { aidate: 2, hokudai: 1 } },
    { label: "当時の暮らしを再現した展示", points: { otaru: 2, yubari: 1 } },
    { label: "標本や研究資料", points: { hokudai: 2, aidate: 1 } },
    { label: "実際に体験できる展示", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "新人が入ってきました", answers: [
    { label: "まず仕事を教える", points: { aidate: 2, hokudai: 1 } },
    { label: "まず仲良くなる", points: { yubari: 2, otaru: 1 } },
    { label: "一緒に研究する", points: { hokudai: 2, aidate: 1 } },
    { label: "館内を案内する", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "一番好きな時間", answers: [
    { label: "展示を直している時間", points: { aidate: 2, otaru: 1 } },
    { label: "仲間とご飯を食べる時間", points: { yubari: 2, otaru: 1 } },
    { label: "新しい発見をした瞬間", points: { hokudai: 2, aidate: 1 } },
    { label: "来館者が笑っている瞬間", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "あなたが残したいものは？", answers: [
    { label: "歴史", points: { aidate: 2, hokudai: 1 } },
    { label: "絆", points: { yubari: 2, otaru: 1 } },
    { label: "知識", points: { hokudai: 2, aidate: 1 } },
    { label: "思い出", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "あなたはどちらかというと？", answers: [
    { label: "職人気質", points: { aidate: 2, hokudai: 1 } },
    { label: "家族思い", points: { yubari: 2, otaru: 1 } },
    { label: "研究者", points: { hokudai: 2, aidate: 1 } },
    { label: "案内役", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "トラブル発生！", answers: [
    { label: "落ち着いて対処する", points: { aidate: 2, hokudai: 1 } },
    { label: "仲間を集める", points: { yubari: 2, otaru: 1 } },
    { label: "原因を分析する", points: { hokudai: 2, aidate: 1 } },
    { label: "来館者を避難させる", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "一番好きな場所", answers: [
    { label: "修復室", points: { aidate: 2, hokudai: 1 } },
    { label: "炭鉱跡", points: { yubari: 2, otaru: 1 } },
    { label: "研究室", points: { hokudai: 2, aidate: 1 } },
    { label: "展示室", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "あなたが一番嬉しいのは？", answers: [
    { label: "展示がきれいになった", points: { aidate: 2, otaru: 1 } },
    { label: "仲間が笑っている", points: { yubari: 2, otaru: 1 } },
    { label: "新発見をした", points: { hokudai: 2, aidate: 1 } },
    { label: "来館者が楽しそうだった", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "あなたに向いている仕事は？", answers: [
    { label: "修復", points: { aidate: 2, hokudai: 1 } },
    { label: "接客", points: { otaru: 2, yubari: 1 } },
    { label: "調査・研究", points: { hokudai: 2, aidate: 1 } },
    { label: "チームをまとめる", points: { yubari: 2, otaru: 1 } },
  ] },
  { text: "一番大切にしたいものは？", answers: [
    { label: "展示物", points: { aidate: 2, hokudai: 1 } },
    { label: "仲間", points: { yubari: 2, otaru: 1 } },
    { label: "真実", points: { hokudai: 2, aidate: 1 } },
    { label: "来館者", points: { otaru: 2, yubari: 1 } },
  ] },
  { text: "最後の質問です。あなたはどんな博物館に勤めたい？", answers: [
    { label: "歴史を未来へ残す博物館", points: { aidate: 2, hokudai: 1 } },
    { label: "家族のような仲間と働く博物館", points: { yubari: 2, otaru: 1 } },
    { label: "世界中の謎を研究する博物館", points: { hokudai: 2, aidate: 1 } },
    { label: "「また来たい」と思われる博物館", points: { otaru: 2, yubari: 1 } },
  ] },
];

const museumDiagnosisMuseums = Object.fromEntries(
  museums.map((museum) => [museum.id, {
    id: museum.id,
    name: museum.name,
    summary: museum.summary || "",
    href: `/museums/${museum.id}/`,
  }])
);

const museumDiagnosisConfig = {
  questions: museumDiagnosisQuestions,
  museums: museumDiagnosisMuseums,
};
---

<BaseLayout title="愛館市立郷土資料館">
  <main>
    <section class="hero" aria-label="創作ロゴと標語">
      <img class="logo-image" src="/images/uploads/logo.webp" alt="愛館市立郷土資料館" />
      <p class="motto">
        形あるものは、いつか壊れる。<br />
        しかし残したいものがある。伝えなければならない事がある。<br />
        それを伝統という。歴史という。
      </p>
    </section>

    <section class="world-section" id="world">
      <p class="tag">WORLD</p>
      <h1 class="section-title">『愛館市立郷土資料館』について</h1>
      <div class="world-copy panel">
        <WorldContent />
      </div>
    </section>

    <section class="showcase-section">
      <p class="tag">CHARACTERS</p>
      <h2 class="section-title">キャラクター</h2>
      <FlowGallery items={characterItems} />
    </section>

    <section class="showcase-section">
      <p class="tag">ILLUSTRATIONS</p>
      <h2 class="section-title">イラスト</h2>
      <FlowGallery items={illustrationItems} type="illustration" />
    </section>


    <section class="member-card-section" id="history-society-card">
      <p class="tag">MEMBERSHIP</p>
      <h2 class="section-title">愛館市歴史研究学会 会員証</h2>

      <div class="member-card-panel panel">
        <form class="member-card-form" id="member-card-form">
          <label>
            <span>プロフィール写真</span>
            <input type="file" id="member-photo" accept="image/*" required />
          </label>
          <label>
            <span>名前</span>
            <input type="text" id="member-name" maxlength="24" required />
          </label>
          <button type="submit">会員証を生成</button>
        </form>

        <div class="member-card-preview" id="member-card-preview" hidden>
          <img id="member-card-image" alt="生成された会員証" />
          <div class="member-card-actions">
            <a id="member-card-download" class="member-card-download" download="aidate-history-society-card.png">PNGを保存</a>
            <button type="button" id="member-card-post" class="member-card-post" disabled>ポストする</button>
          </div>
        </div>
      </div>

      <canvas id="member-card-canvas" width="1200" height="760" hidden></canvas>
    </section>

    <script>
      const memberCardForm = document.querySelector("#member-card-form");
      const memberPhotoInput = document.querySelector("#member-photo");
      const memberNameInput = document.querySelector("#member-name");
      const memberCardCanvas = document.querySelector("#member-card-canvas");
      const memberCardPreview = document.querySelector("#member-card-preview");
      const memberCardImage = document.querySelector("#member-card-image");
      const memberCardDownload = document.querySelector("#member-card-download");
      const memberCardPost = document.querySelector("#member-card-post");
      let latestMemberCardFile = null;
      const memberPostText = "\u611b\u9928\u5e02\u6b74\u53f2\u7814\u7a76\u5b66\u4f1a\u306e\u4f1a\u54e1\u767b\u9332\u3092\u3057\u307e\u3057\u305f\u3002\n#\u611b\u9928\u5e02\u6b74\u53f2\u7814\u7a76\u5b66\u4f1a";

      const loadImageFromUrl = (src) => new Promise((resolve, reject) => {
        const image = new Image();
        image.onload = () => resolve(image);
        image.onerror = reject;
        image.src = src;
      });

      const loadImageFromFile = (file) => new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => {
          const image = new Image();
          image.onload = () => resolve(image);
          image.onerror = reject;
          image.src = reader.result;
        };
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });

      const loadOptionalImage = async (src) => {
        try {
          return await loadImageFromUrl(src);
        } catch {
          return null;
        }
      };

      const formatRegistrationDate = () => {
        const date = new Date();
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const day = String(date.getDate()).padStart(2, "0");
        return year + "." + month + "." + day;
      };

      const drawCoverImage = (ctx, image, x, y, width, height) => {
        const sourceRatio = image.width / image.height;
        const targetRatio = width / height;
        let sourceWidth = image.width;
        let sourceHeight = image.height;
        let sourceX = 0;
        let sourceY = 0;

        if (sourceRatio > targetRatio) {
          sourceWidth = image.height * targetRatio;
          sourceX = (image.width - sourceWidth) / 2;
        } else {
          sourceHeight = image.width / targetRatio;
          sourceY = (image.height - sourceHeight) / 2;
        }

        ctx.drawImage(image, sourceX, sourceY, sourceWidth, sourceHeight, x, y, width, height);
      };

      const createMemberNumber = () => {
        const values = new Uint32Array(1);
        crypto.getRandomValues(values);
        return String((values[0] % 9999) + 1).padStart(4, "0");
      };

      memberCardPost?.addEventListener("click", async () => {
        if (!latestMemberCardFile) return;
        const shareData = {
          title: "\u611b\u9928\u5e02\u6b74\u53f2\u7814\u7a76\u5b66\u4f1a",
          text: memberPostText,
          files: [latestMemberCardFile],
        };

        if (navigator.canShare?.(shareData)) {
          await navigator.share(shareData);
          return;
        }

        const tweetUrl = "https://twitter.com/intent/tweet?text=" + encodeURIComponent(memberPostText);
        window.open(tweetUrl, "_blank", "noopener,noreferrer");
      });
      memberCardForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const file = memberPhotoInput.files?.[0];
        const memberName = memberNameInput.value.trim();
        if (!file || !memberName || !memberCardCanvas) return;

        const ctx = memberCardCanvas.getContext("2d");
        const [logoImage, photoImage, qrImage, stampImage] = await Promise.all([
          loadImageFromUrl("/images/uploads/logo.webp"),
          loadImageFromFile(file),
          loadOptionalImage("/images/uploads/QR_015961.png"),
          loadOptionalImage("/images/uploads/mystamp.png"),
        ]);
        const memberNumber = createMemberNumber();
        const registrationDate = formatRegistrationDate();

        const cardSerif = "'Yu Mincho', 'Hiragino Mincho ProN', 'YuMincho', 'Times New Roman', serif";
        ctx.clearRect(0, 0, memberCardCanvas.width, memberCardCanvas.height);
        ctx.fillStyle = "#f7fbfe";
        ctx.fillRect(0, 0, 1200, 760);

        const gradient = ctx.createLinearGradient(0, 0, 1200, 760);
        gradient.addColorStop(0, "#ffffff");
        gradient.addColorStop(1, "#dcecf4");
        ctx.fillStyle = gradient;
        ctx.fillRect(38, 38, 1124, 684);

        ctx.strokeStyle = "#9eb9cf";
        ctx.lineWidth = 4;
        ctx.strokeRect(38, 38, 1124, 684);

        ctx.save();
        ctx.globalAlpha = 0.065;
        ctx.drawImage(logoImage, 54, 264, 930, 318);
        ctx.restore();

        ctx.fillStyle = "rgba(158, 185, 207, 0.16)";
        ctx.fillRect(760, 38, 402, 684);

        ctx.drawImage(logoImage, 78, 74, 250, 86);

        ctx.fillStyle = "#283745";
        ctx.font = "700 52px " + cardSerif;
        ctx.fillText("愛館市歴史研究学会", 78, 245);

        ctx.fillStyle = "#6f8fa9";
        ctx.font = "700 26px " + cardSerif;
        ctx.fillText("MEMBERSHIP CARD", 82, 292);

        ctx.strokeStyle = "#d8e5ed";
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(82, 328);
        ctx.lineTo(686, 328);
        ctx.stroke();

        ctx.fillStyle = "#6f8292";
        ctx.font = "700 24px " + cardSerif;
        ctx.fillText("会員番号", 82, 402);
        ctx.fillText("会員名", 82, 514);

        ctx.fillStyle = "#283745";
        ctx.font = "700 58px " + cardSerif;
        ctx.fillText(memberNumber, 82, 465);

        ctx.font = "700 48px " + cardSerif;
        ctx.fillText(memberName, 82, 578);

        ctx.fillStyle = "#6f8292";
        ctx.font = "22px " + cardSerif;
        ctx.fillText("Aidate City Historical Research Society", 82, 652);

        ctx.save();
        ctx.beginPath();
        ctx.roundRect(814, 152, 280, 360, 26);
        ctx.clip();
        drawCoverImage(ctx, photoImage, 814, 152, 280, 360);
        ctx.restore();

        ctx.strokeStyle = "#ffffff";
        ctx.lineWidth = 8;
        ctx.strokeRect(814, 152, 280, 360);

        ctx.fillStyle = "#6f8292";
        ctx.font = "700 20px " + cardSerif;
        ctx.fillText("\u767b\u9332\u5e74\u6708\u65e5", 814, 548);
        ctx.fillStyle = "#283745";
        ctx.font = "700 27px " + cardSerif;
        ctx.fillText(registrationDate, 814, 586);

        ctx.fillStyle = "#6f8fa9";
        ctx.font = "700 22px " + cardSerif;
        ctx.fillText("\u611b\u9928\u5e02\u6b74\u53f2\u6587\u5316\u8ca1\u56e3", 814, 642);

        if (stampImage) {
          ctx.save();
          ctx.globalAlpha = 0.88;
          ctx.drawImage(stampImage, 990, 614, 58, 58);
          ctx.restore();
        }

        if (qrImage) {
          ctx.fillStyle = "#ffffff";
          ctx.fillRect(620, 582, 104, 104);
          ctx.drawImage(qrImage, 628, 590, 88, 88);
        }

        const dataUrl = memberCardCanvas.toDataURL("image/png");
        const memberCardBlob = await (await fetch(dataUrl)).blob();
        latestMemberCardFile = new File([memberCardBlob], "aidate-history-society-card-" + memberNumber + ".png", { type: "image/png" });
        memberCardImage.src = dataUrl;
        memberCardDownload.href = dataUrl;
        memberCardDownload.download = latestMemberCardFile.name;
        memberCardPost.disabled = false;
        memberCardPreview.hidden = false;
        memberCardPreview.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    </script>
    <section class="diagnosis-section" id="character-diagnosis">
      <p class="tag">DIAGNOSIS</p>
      <h2 class="section-title">キャラクター診断</h2>
      <p class="lead diagnosis-lead">質問に答えると、あなたに似ているキャラクターを表示します。</p>

      <form class="diagnosis-panel" id="diagnosis-form">
        <p class="diagnosis-progress" id="diagnosis-progress"></p>
        <div class="diagnosis-questions">
          {diagnosisQuestions.map((question, questionIndex) => (
            <fieldset class="diagnosis-question" data-question-index={questionIndex}>
              <legend>{`Q${questionIndex + 1} ${question.text}`}</legend>
              <div class="answer-grid">
                {question.answers.map((answer, answerIndex) => (
                  <label>
                    <input type="radio" name={`question-${questionIndex}`} value={answerIndex} />
                    <span>{answer.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          ))}
        </div>
        <div class="diagnosis-actions">
          <button type="button" id="diagnosis-prev">前の質問へ</button>
          <button type="submit" id="diagnosis-submit">結果を見る</button>
          <button type="button" id="diagnosis-reset">やり直す</button>
        </div>
      </form>

      <article class="diagnosis-result" id="diagnosis-result" hidden aria-live="polite"></article>
      <script id="diagnosis-data" type="application/json" set:html={JSON.stringify(diagnosisConfig)}></script>
    </section>

    <script>
      const diagnosisForm = document.querySelector("#diagnosis-form");
      const diagnosisPrev = document.querySelector("#diagnosis-prev");
      const diagnosisReset = document.querySelector("#diagnosis-reset");
      const diagnosisSubmit = document.querySelector("#diagnosis-submit");
      const diagnosisProgress = document.querySelector("#diagnosis-progress");
      const diagnosisResult = document.querySelector("#diagnosis-result");
      const diagnosisQuestionEls = Array.from(diagnosisForm?.querySelectorAll(".diagnosis-question") || []);
      const diagnosisData = JSON.parse(document.querySelector("#diagnosis-data")?.textContent || "{}");
      let currentDiagnosisQuestion = 0;
      const buildShareUrl = (message) => {
        const url = new URL("https://twitter.com/intent/tweet");
        url.searchParams.set("text", message);
        url.searchParams.set("url", window.location.origin + window.location.pathname);
        return url.toString();
      };

      const updateDiagnosisView = () => {
        const lastIndex = diagnosisQuestionEls.length - 1;
        diagnosisQuestionEls.forEach((question, index) => {
          question.hidden = index !== currentDiagnosisQuestion;
        });
        diagnosisProgress.textContent = `${currentDiagnosisQuestion + 1} / ${diagnosisQuestionEls.length}`;
        diagnosisPrev.disabled = currentDiagnosisQuestion === 0;
        diagnosisSubmit.hidden = currentDiagnosisQuestion !== lastIndex;
      };

      const goToDiagnosisQuestion = (index) => {
        currentDiagnosisQuestion = Math.max(0, Math.min(index, diagnosisQuestionEls.length - 1));
        updateDiagnosisView();
        diagnosisResult.hidden = true;
        diagnosisResult.innerHTML = "";
        diagnosisForm.scrollIntoView({ behavior: "smooth", block: "center" });
      };

      const renderResult = (character) => {
        diagnosisResult.hidden = false;
        diagnosisResult.innerHTML = `
          <div class="result-copy">
            <p class="result-label">診断結果</p>
            <h3>${character.name}</h3>
            ${character.summary ? `<p>${character.summary}</p>` : ""}
            <a href="${character.href}">紹介を見る</a>
            <a class="share-link" href="${buildShareUrl(`キャラクター診断の結果は「${character.name}」でした。`)}" target="_blank" rel="noopener noreferrer">診断結果をポストする</a>
          </div>
          <a class="result-image" href="${character.href}" aria-label="${character.name}の紹介を見る">
            <img src="${character.image}" alt="${character.name}" />
          </a>
        `;
        diagnosisResult.scrollIntoView({ behavior: "smooth", block: "center" });
      };

      diagnosisQuestionEls.forEach((question, questionIndex) => {
        question.querySelectorAll("input[type='radio']").forEach((input) => {
          input.addEventListener("change", () => {
            diagnosisResult.hidden = true;
            diagnosisResult.innerHTML = "";
            if (questionIndex < diagnosisQuestionEls.length - 1) {
              window.setTimeout(() => goToDiagnosisQuestion(questionIndex + 1), 220);
            } else {
              updateDiagnosisView();
            }
          });
        });
      });

      diagnosisPrev?.addEventListener("click", () => {
        goToDiagnosisQuestion(currentDiagnosisQuestion - 1);
      });

      diagnosisForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        const scores = Object.fromEntries(Object.keys(diagnosisData.characters || {}).map((id) => [id, 0]));

        for (let questionIndex = 0; questionIndex < diagnosisData.questions.length; questionIndex += 1) {
          const selected = diagnosisForm.querySelector(`input[name="question-${questionIndex}"]:checked`);
          if (!selected) {
            goToDiagnosisQuestion(questionIndex);
            diagnosisResult.hidden = false;
            diagnosisResult.innerHTML = `<p class="diagnosis-warning">まだ答えていない質問があります。</p>`;
            return;
          }

          const answer = diagnosisData.questions[questionIndex].answers[Number(selected.value)];
          Object.entries(answer.points).forEach(([id, point]) => {
            scores[id] = (scores[id] || 0) + point;
          });
        }

        const winnerId = Object.entries(scores).sort((a, b) => b[1] - a[1])[0]?.[0];
        const winner = diagnosisData.characters[winnerId];
        if (winner) renderResult(winner);
      });

      diagnosisReset?.addEventListener("click", () => {
        diagnosisForm.reset();
        currentDiagnosisQuestion = 0;
        updateDiagnosisView();
        diagnosisResult.hidden = true;
        diagnosisResult.innerHTML = "";
        diagnosisForm.scrollIntoView({ behavior: "smooth", block: "center" });
      });

      updateDiagnosisView();
    </script>
