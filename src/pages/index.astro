  }

  .top-news-item span {
    line-height: 1.6;
    font-weight: 700;
  }

  .top-news-item:hover span {
    color: var(--blue-deep);
  }

  .showcase-section {
    padding: 56px 0;
  }

  .member-card-section {
    padding: 64px 0 36px;
  }

  .member-card-panel {
    font-family: "Yu Mincho", "Hiragino Mincho ProN", "YuMincho", serif;
    display: grid;
    grid-template-columns: minmax(0, 360px) 1fr;
    gap: clamp(18px, 4vw, 34px);
    align-items: start;
    padding: clamp(20px, 4vw, 34px);
  }

  .member-card-form {
    display: grid;
    gap: 16px;
  }

  .member-card-form label {
    display: grid;
    gap: 8px;
    color: var(--ink);
    font-weight: 700;
  }

  .member-card-form input[type="text"],
  .member-card-form input[type="file"] {
    width: 100%;
    min-height: 46px;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fffdf9;
    color: var(--ink);
    font: inherit;
  }

  .member-card-form button,
  .member-card-download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 22px;
    border: 1px solid var(--blue-deep);
    border-radius: 999px;
    background: var(--blue-deep);
    color: #fff;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }

  .member-card-preview {
    display: grid;
    gap: 14px;
    justify-items: start;
