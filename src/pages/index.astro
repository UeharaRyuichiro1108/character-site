---

<BaseLayout title="愛館市立郷土資料館">
  <main>
    <section class="hero" aria-label="創作ロゴと標語">
      <img class="logo-image" src="/images/uploads/logo.webp" alt="愛館市立郷土資料館" />
      <p class="motto">
        形あるものは、いつか壊れる。<br />
        しかし残したいものがある。伝えなければならない事がある。<br />
        それを伝統という。歴史という。
      </p>
    </section>

    <section class="world-section" id="world">
      <p class="tag">WORLD</p>
      <h1 class="section-title">『愛館市立郷土資料館』について</h1>
      <div class="world-copy panel">
        <WorldContent />
      </div>
    </section>

    <section class="ticket-section" id="museum-ticket-machine" aria-label="入館証発行機">
      <div class="section-heading-row ticket-heading">
        <div>
          <p class="tag">ADMISSION TICKET</p>
          <h2 class="section-title">入館証発行機</h2>
        </div>
      </div>

      <div class="ticket-machine panel" id="ticket-machine">
        <div class="ticket-printer">
          <div class="printer-display">
            <span class="printer-light" aria-hidden="true"></span>
            <span class="printer-label">AIDATE MUSEUM</span>
            <span class="printer-status">READY</span>
          </div>
          <button class="ticket-issue-button" type="button" id="ticket-issue-button">入館証発行</button>
          <span class="printer-slot" aria-hidden="true"></span>
        </div>

        <div class="ticket-output" aria-live="polite">
          <article class="museum-ticket" id="museum-ticket">
            <div class="ticket-main">
              <a class="ticket-art-link" id="ticket-art-link" href="/illustrations/">
                <img id="ticket-art-image" src="/images/uploads/logo.webp" alt="入館証に印刷されたイラスト" />
                <span class="ticket-art-watermark">愛館市立郷土資料館</span>
              </a>
            </div>
            <div class="ticket-stub">
              <span class="ticket-perforation" aria-hidden="true"></span>
              <div class="ticket-stub-copy">
                <strong>常設展示</strong>
                <time id="ticket-date"></time>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div class="ticket-result" id="ticket-result" hidden>
        <p>ごゆっくりご観覧ください</p>
        <a class="ticket-share-button" href="https://twitter.com/intent/tweet?text=%E6%84%9B%E9%A4%A8%E5%B8%82%E7%AB%8B%E9%83%B7%E5%9C%9F%E8%B3%87%E6%96%99%E9%A4%A8%E3%81%AB%E5%85%A5%E9%A4%A8%E3%81%97%E3%81%BE%E3%81%97%E3%81%9F%E3%80%82%0A%23%E6%84%9B%E9%A4%A8%E5%B8%82%E6%AD%B4%E5%8F%B2%E7%A0%94%E7%A9%B6%E5%AD%A6%E4%BC%9A" target="_blank" rel="noopener noreferrer">Xで共有する</a>
      </div>
    </section>

    <script type="application/json" id="ticket-illustrations" set:html={JSON.stringify(ticketIllustrations)}></script>
    <script>
      const ticketDataElement = document.querySelector("#ticket-illustrations");
      const ticketIllustrations = JSON.parse(ticketDataElement?.textContent || "[]");
      const ticketButton = document.querySelector("#ticket-issue-button");
      const ticketMachine = document.querySelector("#ticket-machine");
      const ticket = document.querySelector("#museum-ticket");
      const ticketResult = document.querySelector("#ticket-result");
      const ticketImage = document.querySelector("#ticket-art-image");
      const ticketLink = document.querySelector("#ticket-art-link");
      const ticketDate = document.querySelector("#ticket-date");

      const formatTicketDate = () => {
        const date = new Date();
        return date.toLocaleDateString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit" });
      };

      const issueTicket = () => {
        if (!ticket || !ticketMachine) return;
        const selected = ticketIllustrations[Math.floor(Math.random() * ticketIllustrations.length)] || {
          title: "愛館市立郷土資料館",
          image: "/images/uploads/logo.webp",
          href: "/illustrations/",
        };

        ticketImage.src = selected.image;
        ticketLink.href = selected.href;
        ticketDate.textContent = formatTicketDate();
        ticketResult.hidden = true;

        ticketMachine.classList.remove("is-issued");
        ticket.classList.remove("is-printing");
        window.setTimeout(() => {
          ticketMachine.classList.add("is-issued");
          ticket.classList.add("is-printing");
        }, 40);
        window.setTimeout(() => {
          ticketResult.hidden = false;
        }, 2600);
      };

      ticketButton?.addEventListener("click", issueTicket);
    </script>
    <section class="ad-section" aria-label="幻覚広告欄">
      <div class="section-heading-row">
        <div>
          <p class="tag">FAKE ADVERTISEMENT</p>
          <h2 class="section-title">幻覚広告欄</h2>
          <p class="ad-note">※内容はすべて嘘です</p>
        </div>
        <a class="section-link" href="/ads/">広告一覧を見る</a>
      </div>
      <div class="ad-carousel" data-ad-carousel data-ad-count={latestAds.length}>
        <button class="ad-arrow ad-arrow-prev" type="button" data-ad-prev aria-label="前の広告へ">‹</button>
        <div class="ad-track" data-ad-track tabindex="0">
          {loopingAds.map((ad) => (
            <a class="ad-slide" href={`/ads/${ad.id}/`}>
              <img src={ad.bannerImage} alt={`${ad.title}のバナー`} loading="lazy" />
              <span>{ad.title}</span>
            </a>
          ))}
        </div>
        <button class="ad-arrow ad-arrow-next" type="button" data-ad-next aria-label="次の広告へ">›</button>
      </div>
    </section>

    <section class="news-section" aria-label="お知らせ">
      <div class="section-heading-row">
        <div>
          <p class="tag">NEWS</p>
          <h2 class="section-title">お知らせ</h2>
        </div>
        <a class="section-link" href="/news/">一覧を見る</a>
      </div>
      <div class="top-news-list panel">
        {latestNews.map((item) => (
          <a class="top-news-item" href={`/news/${item.id}/`}>
            <time datetime={item.publishedAt}>{formatDate(item.publishedAt)}</time>
            <span>{item.title}</span>
          </a>
        ))}
      </div>
    </section>

    <script>
      const adCarousel = document.querySelector("[data-ad-carousel]");
      const adTrack = document.querySelector("[data-ad-track]");
      const adSlides = Array.from(document.querySelectorAll(".ad-slide"));
      const adPrev = document.querySelector("[data-ad-prev]");
      const adNext = document.querySelector("[data-ad-next]");
      const originalAdCount = Number(adCarousel?.dataset.adCount || adSlides.length);
      let currentAdIndex = 0;
      let adResetTimer;
      let adScrollSyncTimer;
      let adTouchStartX = 0;
      let adTouchStartY = 0;

      const getAdLeft = (index) => {
        const target = adSlides[index];
        return target ? target.offsetLeft - adTrack.offsetLeft : 0;
      };

      const jumpToAd = (index) => {
        if (!adTrack || adSlides.length === 0) return;
        adTrack.scrollTo({ left: getAdLeft(index), behavior: "auto" });
      };

      const scrollToAd = (index) => {
        if (!adTrack || adSlides.length === 0 || originalAdCount <= 0) return;
        window.clearTimeout(adResetTimer);

        if (index < 0 && originalAdCount > 1) {
          currentAdIndex = originalAdCount;
          jumpToAd(currentAdIndex);
          index = originalAdCount - 1;
        }

        currentAdIndex = index;
        adTrack.scrollTo({ left: getAdLeft(currentAdIndex), behavior: "smooth" });

        if (currentAdIndex >= originalAdCount) {
          adResetTimer = window.setTimeout(() => {
            currentAdIndex = 0;
            jumpToAd(currentAdIndex);
          }, 650);
        }
      };

      adTrack?.addEventListener("scroll", () => {
        window.clearTimeout(adScrollSyncTimer);
        adScrollSyncTimer = window.setTimeout(() => {
          if (!adTrack || adSlides.length === 0 || originalAdCount <= 0) return;
          const currentLeft = adTrack.scrollLeft;
          const nearestIndex = adSlides.reduce((nearest, slide, index) => {
            const distance = Math.abs(slide.offsetLeft - adTrack.offsetLeft - currentLeft);
            const nearestDistance = Math.abs(adSlides[nearest].offsetLeft - adTrack.offsetLeft - currentLeft);
            return distance < nearestDistance ? index : nearest;
          }, currentAdIndex);

          currentAdIndex = nearestIndex;
          if (currentAdIndex >= originalAdCount) {
            currentAdIndex -= originalAdCount;
            jumpToAd(currentAdIndex);
          }
        }, 160);
      });

      adTrack?.addEventListener("touchstart", (event) => {
        const touch = event.touches[0];
        adTouchStartX = touch.clientX;
        adTouchStartY = touch.clientY;
      }, { passive: true });

      adTrack?.addEventListener("touchend", (event) => {
        const touch = event.changedTouches[0];
        const distanceX = touch.clientX - adTouchStartX;
        const distanceY = touch.clientY - adTouchStartY;
        if (Math.abs(distanceX) < 36 || Math.abs(distanceX) < Math.abs(distanceY)) return;
        scrollToAd(currentAdIndex + (distanceX < 0 ? 1 : -1));
      }, { passive: true });

      adPrev?.addEventListener("click", () => scrollToAd(currentAdIndex - 1));
      adNext?.addEventListener("click", () => scrollToAd(currentAdIndex + 1));

      if (originalAdCount > 1) {
        window.setInterval(() => scrollToAd(currentAdIndex + 1), 5200);
      }
    </script>

