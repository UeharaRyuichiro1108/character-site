    max-height: 520px;
    height: auto;
    object-fit: contain;
  }

  .motto {
    max-width: 820px;
    margin: 0;
    color: var(--muted);
    font-family: "MySiteFont", "Yu Mincho", "Hiragino Mincho ProN", serif;
    font-size: clamp(12px, 1.45vw, 16px);
    line-height: 1.75;
  }

  .world-section {
    padding: 72px 0 56px;
  }

  .world-copy {
    padding: clamp(24px, 5vw, 48px);
    line-height: 2;
  }

  .world-copy :global(h2) {
    margin-top: 34px;
    color: var(--blue-deep);
  }

  .ticket-section {
    padding: 56px 0 24px;
  }

  .ticket-heading {
    gap: 18px;
  }

  .ticket-issue-button,
  .ticket-share-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 22px;
    border: 1px solid var(--blue-deep);
    border-radius: 999px;
    background: var(--blue-deep);
    color: #fff;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 14px 28px rgba(61, 93, 115, 0.18);
    transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .ticket-issue-button {
    justify-self: stretch;
    min-height: 50px;
    padding: 0 18px;
    border-color: rgba(255, 255, 255, 0.72);
    border-radius: 14px;
    background: linear-gradient(180deg, #f9fdff, #d9ebf4);
    color: #2b4b62;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      0 8px 0 #8fb2c8,
      0 16px 26px rgba(44, 73, 94, 0.18);
  }

  .ticket-issue-button:hover,
  .ticket-share-button:hover {
    transform: translateY(-2px);
    background: #42677f;
    box-shadow: var(--soft-shadow);
  }

  .ticket-issue-button:hover {
    background: linear-gradient(180deg, #ffffff, #cce5f0);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.94),
      0 7px 0 #7da8c1,
      0 16px 28px rgba(44, 73, 94, 0.2);
  }

  .ticket-issue-button:active {
    transform: translateY(5px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 2px 0 #7da8c1,
      0 8px 18px rgba(44, 73, 94, 0.18);
  }

  .ticket-machine {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 0;
    max-width: 600px;
    margin: 18px auto 0;
    padding: 34px 18px 36px;
    overflow: hidden;
    background:
      radial-gradient(circle at 22% 8%, rgba(255, 255, 255, 0.92), transparent 30%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(226, 241, 248, 0.92));
  }

  .ticket-machine::before {
    content: "";
    position: absolute;
    inset: 14px;
    border: 1px solid rgba(134, 171, 193, 0.35);
    border-radius: 16px;
    pointer-events: none;
  }

  .ticket-printer {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(132px, 150px);
    gap: 16px;
    align-items: center;
    width: min(420px, 84vw);
    min-height: 138px;
    padding: 20px 24px 34px;
    border: 1px solid rgba(111, 150, 174, 0.68);
    border-radius: 24px 24px 14px 14px;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, 0.62), transparent 42%),
      linear-gradient(180deg, #eef8fc, #bcd8e8 52%, #779fb7);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.86),
      inset 0 -12px 22px rgba(51, 86, 109, 0.12),
      0 24px 46px rgba(62, 91, 112, 0.24);
  }

  .printer-display {
    display: grid;
    grid-template-columns: 12px 1fr;
    gap: 8px 10px;
    align-items: center;
    min-height: 70px;
    padding: 14px 16px;
    border: 1px solid rgba(49, 78, 96, 0.32);
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(36, 61, 78, 0.92), rgba(22, 39, 52, 0.92));
    color: #dff3ff;
    box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.28);
  }

  .printer-light {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #83e0ad;
    box-shadow: 0 0 0 4px rgba(131, 224, 173, 0.18), 0 0 14px rgba(131, 224, 173, 0.72);
  }

  .printer-label {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
  }

  .printer-status {
    grid-column: 2;
    color: #9fd3eb;
    font-family: ui-monospace, "Cascadia Mono", Consolas, monospace;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .printer-slot {
    position: absolute;
    left: 50%;
    bottom: 16px;
    width: min(312px, 70vw);
    height: 12px;
    border-radius: 999px;
    background: linear-gradient(180deg, #172d3d, #385a70);
    box-shadow: inset 0 3px 7px rgba(0, 0, 0, 0.42), 0 1px 0 rgba(255, 255, 255, 0.28);
    transform: translateX(-50%);
  }

  .ticket-output {
    position: relative;
    display: grid;
    justify-items: center;
    width: min(360px, 82vw);
    height: 560px;
    margin-top: -2px;
    overflow: hidden;
  }

  .museum-ticket {
    display: grid;
    grid-template-rows: 1fr 118px;
    width: min(300px, 72vw);
    min-height: 520px;
    border: 1px solid #8d5a32;
    border-radius: 18px;
    overflow: hidden;
    background: #f7d8a3;
    color: #64380f;
    box-shadow: 0 22px 44px rgba(75, 49, 24, 0.2);
    transform: translateY(-110%);
  }

  .museum-ticket.is-printing {
    animation: printTicket 2.45s cubic-bezier(0.18, 0.78, 0.22, 1) forwards;
  }

  .ticket-main {
    display: grid;
    align-content: start;
    gap: 10px;
    padding: 24px 22px 20px;
    background:
      linear-gradient(90deg, rgba(106, 58, 21, 0.12) 1px, transparent 1px) 0 0 / 100% 100%,
      radial-gradient(circle at 18px 18px, rgba(106, 58, 21, 0.1), transparent 18px),
      #f6d59a;
  }

  .ticket-small,
  .ticket-sub,
  .ticket-art-title {
    margin: 0;
    text-align: center;
    letter-spacing: 0.08em;
  }

  .ticket-small {
    font-size: 11px;
    font-weight: 700;
  }

  .ticket-main h3 {
    margin: 0;
    font-size: clamp(24px, 7vw, 38px);
    line-height: 1.15;
    text-align: center;
    letter-spacing: 0;
  }

  .ticket-sub {
    font-size: 13px;
    font-weight: 800;
  }

  .ticket-art-link {
    display: block;
    aspect-ratio: 4 / 3;
    margin-top: 8px;
    overflow: hidden;
    border: 2px solid rgba(100, 56, 15, 0.42);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.5);
  }

  .ticket-art-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ticket-art-title {
    min-height: 1.8em;
    color: #7b4a1c;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.5;
  }

  .ticket-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin: 8px 0 0;
    padding-top: 12px;
    border-top: 1px solid rgba(100, 56, 15, 0.34);
  }

  .ticket-meta div {
    display: grid;
    gap: 3px;
  }

  .ticket-meta dt {
    color: rgba(100, 56, 15, 0.72);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
  }

  .ticket-meta dd {
    margin: 0;
    font-size: 16px;
    font-weight: 800;
  }

  .ticket-stub {
    position: relative;
    display: grid;
    grid-template-columns: 28px 1fr 42px;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background: #64380f;
    color: #f8dca8;
  }

  .ticket-perforation {
    align-self: stretch;
    border-left: 6px dotted #fff8ea;
  }

  .ticket-barcode {
    width: 100%;
    height: 72px;
    background: repeating-linear-gradient(90deg, #f8dca8 0 3px, transparent 3px 7px, #f8dca8 7px 9px, transparent 9px 14px);
  }

  .ticket-stub-number {
    writing-mode: vertical-rl;
    justify-self: center;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .ticket-result {
    display: grid;
    justify-items: center;
    gap: 14px;
    margin-top: 18px;
  }

  .ticket-result[hidden] {
    display: none;
  }

  .ticket-result p {
    margin: 0;
    color: var(--blue-deep);
    font-size: clamp(18px, 3vw, 26px);
    font-weight: 700;
  }

  @media (max-width: 520px) {
    .ticket-printer {
      grid-template-columns: 1fr;
      gap: 14px;
      width: min(340px, 84vw);
      padding: 18px 18px 34px;
    }

    .ticket-issue-button {
      min-height: 48px;
    }
  }

