---
import worldPage from "../content/pages/world.md";

const { frontmatter } = worldPage;
const WorldContent = worldPage.default;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{frontmatter.title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <p><a href="/">トップへ戻る</a></p>
      <h1>{frontmatter.title}</h1>

      <div class="content">
        <WorldContent />
      </div>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: "Yu Gothic", "Meiryo", sans-serif;
    background: #11131a;
    color: #f5f1e8;
  }

  main {
    width: min(760px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0;
    line-height: 1.9;
  }

  .content {
    line-height: 1.9;
  }
</style>