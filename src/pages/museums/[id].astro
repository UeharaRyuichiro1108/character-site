---
import BaseLayout from "../../components/BaseLayout.astro";

export function getStaticPaths() {
  const museumModules = import.meta.glob("../../content/museums/*.md", { eager: true });
  const museums = Object.values(museumModules).map((module) => ({
    ...module.frontmatter,
    Content: module.default,
  }));

  return museums.map((museum) => ({
    params: { id: museum.id },
    props: { museum },
  }));
}

const characterModules = import.meta.glob("../../content/characters/*.md", { eager: true });
const characters = Object.values(characterModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
}));

const { museum } = Astro.props;
const MuseumContent = museum.Content;
const members = characters.filter((character) => character.museumId === museum.id);
---

<BaseLayout title={museum.name}>
  <main class="page-shell">
    <p class="tag"><a href="/museums/">博物館一覧へ戻る</a></p>
    <h1 class="page-title">{museum.name}</h1>
    <p class="lead">{museum.summary}</p>

    <section class="museum-body panel">
      <MuseumContent />
    </section>

    <section class="members-section">
      <h2 class="section-title">所属キャラクター</h2>
      <div class="member-grid">
        {members.map((character) => (
          <a class="member" href={`/characters/${character.id}/`}>
            <img src={character.image} alt={character.name} />
            <span>{character.name}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .tag a {
    color: var(--blue-deep);
    text-decoration: none;
  }

  .museum-body {
    margin-top: 28px;
    padding: clamp(24px, 5vw, 44px);
    color: var(--muted);
    line-height: 2;
  }

  .members-section {
    margin-top: 52px;
  }

  .member-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(126px, 1fr));
    gap: 22px;
  }

  .member {
    display: grid;
    gap: 10px;
    justify-items: center;
    color: var(--ink);
    font-weight: 700;
    text-align: center;
    text-decoration: none;
  }

  .member img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: 18px;
    box-shadow: var(--soft-shadow);
  }
</style>