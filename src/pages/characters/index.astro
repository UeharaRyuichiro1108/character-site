---
import BaseLayout from "../../components/BaseLayout.astro";

const characterModules = import.meta.glob("../../content/characters/*.md", { eager: true });
const characters = Object.values(characterModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
}));

const groups = [...new Set(characters.map((character) => character.group))];
---

<BaseLayout title="キャラクター一覧">
  <main class="page-shell">
    <h1 class="page-title">キャラクター</h1>
    <p class="lead">所属する博物館ごとに、展示人物を一覧できます。</p>

    {groups.map((group) => (
      <section class="group-section">
        <h2 class="section-title">{group}</h2>
        <div class="character-grid">
          {characters
            .filter((character) => character.group === group)
            .map((character) => (
              <a class="character-tile" href={`/characters/${character.id}/`}>
                <img src={character.image} alt={character.name} />
                <span>{character.name}</span>
              </a>
            ))}
        </div>
      </section>
    ))}
  </main>
</BaseLayout>

<style>
  .group-section {
    margin-top: 48px;
  }

  .character-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(128px, 1fr));
    gap: clamp(18px, 3vw, 28px);
  }

  .character-tile {
    display: grid;
    gap: 12px;
    justify-items: center;
    color: var(--ink);
    font-weight: 700;
    text-align: center;
    text-decoration: none;
  }

  .character-tile img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--paper);
    box-shadow: var(--soft-shadow);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .character-tile:hover img {
    transform: translateY(-4px);
    box-shadow: 0 20px 52px rgba(93, 125, 148, 0.22);
  }
</style>
