---
export function getStaticPaths() {
  const characterModules = import.meta.glob("../../content/characters/*.md", {
    eager: true,
  });

  const characters = Object.values(characterModules).map((module) => ({
    ...module.frontmatter,
    Content: module.default,
  }));

  return characters.map((character) => ({
    params: { id: character.id },
    props: { character },
  }));
}

const illustrationModules = import.meta.glob("../../content/illustrations/*.md", {
  eager: true,
});

const illustrations = Object.values(illustrationModules).map((module) => ({
  ...module.frontmatter,
  Content: module.default,
}));

const { character } = Astro.props;
const CharacterContent = character.Content;

const relatedIllustrations = illustrations.filter((illustration) =>
  illustration.tags?.includes(character.id)
);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{character.name}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <p><a href="/characters/">キャラクター一覧へ戻る</a></p>

      <section class="profile">
        <img src={character.image} alt={character.name} />

        <div>
          <p class="group">{character.group}</p>
          <h1>{character.name}</h1>
          <p>{character.catchcopy}</p>

          <dl class="profile-list">
            <div>
              <dt>性別</dt>
              <dd>{character.gender}</dd>
            </div>
            <div>
              <dt>身長</dt>
              <dd>{character.height}</dd>
            </div>
            <div>
              <dt>年齢</dt>
              <dd>{character.age}</dd>
            </div>
            <div>
              <dt>役職</dt>
              <dd>{character.role}</dd>
            </div>
            <div>
              <dt>性格</dt>
              <dd>{character.personality}</dd>
            </div>
            <div>
              <dt>特技</dt>
              <dd>{character.skill}</dd>
            </div>
            <div>
              <dt>能力</dt>
              <dd>{character.ability}</dd>
            </div>
            <div>
              <dt>生い立ち</dt>
              <dd>{character.background}</dd>
            </div>
            <div>
              <dt>その他</dt>
              <dd>{character.other}</dd>
            </div>
          </dl>

          {character.designImage && (
            <section class="design">
              <h2>デザイン画</h2>
              <img src={character.designImage} alt={`${character.name}のデザイン画`} />
            </section>
          )}

          <div class="description">
            <CharacterContent />
          </div>
        </div>
      </section>

      <section>
        <h2>関連イラスト</h2>

        {relatedIllustrations.length === 0 ? (
          <p>関連イラストはまだありません。</p>
        ) : (
          <div class="grid">
            {relatedIllustrations.map((illustration) => (
              <article class="card">
                <img src={illustration.image} alt={illustration.title} />
                <h3>{illustration.title}</h3>
              </article>
            ))}
          </div>
        )}
      </section>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: "Yu Gothic", "Meiryo", sans-serif;
    background: #11131a;
    color: #f5f1e8;
  }

  main {
    width: min(1000px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0;
  }

  .profile {
    display: grid;
    grid-template-columns: minmax(220px, 360px) 1fr;
    gap: 24px;
    align-items: start;
  }

  .profile img {
    width: 100%;
    border-radius: 8px;
  }

  .group {
    color: #9cc7ff;
  }

  .description {
    line-height: 1.9;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .card {
    background: #1b1f2a;
    border: 1px solid #343a4a;
    border-radius: 8px;
    padding: 16px;
  }

  .card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 6px;
  }

  @media (max-width: 700px) {
    .profile {
      grid-template-columns: 1fr;
    }
  }

    .profile-list {
    display: grid;
    gap: 12px;
    margin: 24px 0;
  }

  .profile-list div {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid #343a4a;
  }

  .profile-list dt {
    color: #9cc7ff;
    font-weight: bold;
  }

  .profile-list dd {
    margin: 0;
    line-height: 1.8;
  }

  .design {
    margin: 32px 0;
  }

  .design img {
    width: 100%;
    max-width: 720px;
    border-radius: 8px;
    border: 1px solid #343a4a;
  }

  @media (max-width: 700px) {
    .profile-list div {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>