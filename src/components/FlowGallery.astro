---
const { items, type = "character" } = Astro.props;
const repeatedItems = [...items, ...items, ...items];
const galleryId = `flow-${type}-${Math.random().toString(36).slice(2)}`;
---

<div class="flow-gallery" id={galleryId} data-count={items.length} aria-label={type === "character" ? "キャラクター紹介" : "イラスト紹介"}>
  <div class="flow-track">
    {repeatedItems.map((item) => (
      <a class="flow-card" href={item.href}>
        <img src={item.image} alt={item.title} />
        <span>{item.title}</span>
      </a>
    ))}
  </div>
</div>

<script define:vars={{ galleryId }}>
  const gallery = document.getElementById(galleryId);
  const track = gallery?.querySelector(".flow-track");
  const cards = Array.from(gallery?.querySelectorAll(".flow-card") ?? []);
  const originalCount = Number(gallery?.dataset.count ?? 0);
  let offset = 0;
  let paused = false;
  let animationFrameId = 0;

  const getLoopWidth = () => {
    if (!cards.length || !originalCount) return 0;
    const first = cards[0];
    const width = first.getBoundingClientRect().width;
    return width * originalCount;
  };

  const tick = () => {
    if (track && !paused) {
      const loopWidth = getLoopWidth();
      offset -= 0.55;
      if (loopWidth > 0 && Math.abs(offset) >= loopWidth) {
        offset = 0;
      }
      track.style.transform = `translate3d(${offset}px, 0, 0)`;
    }
    animationFrameId = window.requestAnimationFrame(tick);
  };

  gallery?.addEventListener("mouseenter", () => {
    paused = true;
  });

  gallery?.addEventListener("mouseleave", () => {
    paused = false;
  });

  window.addEventListener("resize", () => {
    offset = 0;
    if (track) track.style.transform = "translate3d(0, 0, 0)";
  });

  animationFrameId = window.requestAnimationFrame(tick);
  document.addEventListener("astro:before-swap", () => window.cancelAnimationFrame(animationFrameId), { once: true });
</script>

<style>
  .flow-gallery {
    overflow: hidden;
  }

  .flow-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .flow-card {
    position: relative;
    display: block;
    flex: 0 0 auto;
    width: clamp(138px, 18vw, 220px);
    height: clamp(280px, 42vw, 440px);
    overflow: hidden;
    color: #fff;
    text-decoration: none;
  }

  .flow-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .flow-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(24, 45, 62, 0.04), rgba(24, 45, 62, 0.55));
  }

  .flow-card span {
    position: absolute;
    right: 14px;
    bottom: 16px;
    left: 14px;
    z-index: 1;
    font-weight: 700;
    text-shadow: 0 2px 12px rgba(25, 35, 45, 0.5);
  }

  .flow-card:hover img {
    transform: scale(1.04);
  }
</style>