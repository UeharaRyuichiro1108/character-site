---
const {
  title = "愛館市立郷土資料館",
  description = "愛館市立郷土資料館",
  image = "/images/uploads/aidate.webp",
} = Astro.props;

const siteName = "愛館市立郷土資料館";
const siteUrl = "https://aidate-museum.uehararyuichiro.workers.dev";
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const fallbackImage = "/images/uploads/aidate.webp";
const safeImage = image || fallbackImage;
const imageUrl = new URL(safeImage, siteUrl).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  alternateName: "愛館市歴史研究学会",
  url: siteUrl,
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="application-name" content={siteName} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:url" content={pageUrl} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="TOPへ戻る"><img src="/images/uploads/logo.webp" alt="愛館市立郷土資料館" /></a>
      <nav class="nav" aria-label="主要ナビゲーション">
        <a href="/">TOP</a>
        <a href="/characters/">キャラクター</a>

        <a href="/illustrations/">イラスト</a>
        <a href="/novels/">小説</a>
        <a href="/columns/">博物館館報</a>
        <a href="/museums/">博物館一覧</a>
        <a href="/relationships/">相関図</a>
        <a href="/guestbook/">来館者ノート</a>
        <a href="/gifted-illustrations/">描いていただいたイラスト</a>
      </nav>
    </header>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --ink: #283745;
    --muted: #6f8292;
    --pale: #edf6fb;
    --pale-2: #dcecf4;
    --blue: #9eb9cf;
    --blue-deep: #6f8fa9;
    --line: #d8e5ed;
    --paper: #ffffff;
    --soft-shadow: 0 18px 48px rgba(93, 125, 148, 0.16);
  }

  @font-face {
  font-family: "MySiteFont";
    src: url("/fonts/UtsukushiFONT.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: "MySiteFont", "Yu Gothic", "Meiryo", sans-serif;
    color: var(--ink);
    background: linear-gradient(180deg, #f8fcff 0%, #eef7fb 44%, #ffffff 100%);
    letter-spacing: 0;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px clamp(16px, 4vw, 48px);
    background: #ffffff;
    border-bottom: 1px solid rgba(158, 185, 207, 0.38);
    box-shadow: 0 8px 24px rgba(93, 125, 148, 0.08);
  }

  .brand {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    width: 216px;
    height: 72px;
    overflow: hidden;
    text-decoration: none;
  }

  .brand img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(10px, 2vw, 22px);
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }

  .nav::-webkit-scrollbar {
    display: none;
  }

  .nav a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    color: var(--ink);
    font-size: 14px;
      font-weight: 700;
    text-decoration: none;
  }

  .nav a:hover {
    color: var(--blue-deep);
  }

  main {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .page-shell {
    padding: 48px 0 72px;
  }

  .page-title {
    margin: 0 0 28px;
    font-size: clamp(32px, 6vw, 64px);
    color: var(--ink);
  }

  .section-title {
    margin: 0 0 22px;
    color: var(--ink);
    font-size: clamp(24px, 4vw, 38px);
  }

  .lead {
    color: var(--muted);
    line-height: 2;
  }

  .panel {
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--soft-shadow);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    color: var(--blue-deep);
    font-size: 13px;
      font-weight: 700;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }

    .nav {
      width: 100%;
      justify-content: flex-start;
    }
  }
</style>







